# =============================================================================
# AI Webapp Starter AWS - 環境変数テンプレート
# =============================================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_webapp_dev?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_webapp_dev

# -----------------------------------------------------------------------------
# Backend (NestJS)
# -----------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="AI Webapp Starter"

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# RAG (Optional)
# -----------------------------------------------------------------------------
# VECTOR_DB_URL=http://localhost:6333
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# AWS (本番環境用)
# -----------------------------------------------------------------------------
# AWS_REGION=ap-northeast-1
# AWS_ACCOUNT_ID=123456789012
# ECR_REPOSITORY_WEB=ai-webapp-web
# ECR_REPOSITORY_API=ai-webapp-api
# APP_RUNNER_SERVICE_ARN=arn:aws:apprunner:...
# AWS_SECRETS_NAME=ai-webapp/production

# -----------------------------------------------------------------------------
# PentAGI (セキュリティテスト用 - ステージング環境限定)
# -----------------------------------------------------------------------------
# PENTAGI_API_URL=http://localhost:8080
# PENTAGI_API_KEY=your-pentagi-api-key
# PENTAGI_TARGET_URL=http://staging.example.com
