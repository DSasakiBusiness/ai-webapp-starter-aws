{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.sh"],
      "ignoreDependencies": [
        "turbo",
        "@playwright/test",
        "wait-on",
        "husky",
        "lint-staged",
        "npm-check-updates",
        "depcheck",
        "sort-package-json",
        "madge",
        "cspell"
      ]
    },
    "apps/api": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["**/*.spec.ts", "**/*.test.ts"]
    },
    "apps/web": {
      "entry": ["src/app/layout.tsx", "src/app/page.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["**/*.test.ts", "**/*.test.tsx"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
